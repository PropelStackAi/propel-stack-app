# ---- Database (Supabase / any PostgreSQL) ----
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ---- AI keys (at least one required for AI features) ----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AI...

# ---- Stripe (optional — required for billing) ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Auth (set a long random string) ----
JWT_SECRET=change-me-32-chars-minimum
SESSION_SECRET=change-me-too

# ---- CORS (set to your Vercel URL, e.g. https://your-app.vercel.app) ----
ALLOWED_ORIGIN=https://your-app.vercel.app

# ---- Email (optional) ----
RESEND_API_KEY=

# ---- Observability (optional) ----
SENTRY_DSN=
POSTHOG_API_KEY=

# ---- Runtime ----
NODE_ENV=production
PORT=5000

# ---- Client-side (set in Vercel environment variables, NOT in this file) ----
# VITE_API_URL=https://your-railway-app.up.railway.app
